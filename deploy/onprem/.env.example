# pgwatch — tek Linux sunucu, on-prem (internete kapalı)
# Kopyalayın: cp .env.example .env  → değerleri düzenleyin

# Uygulama veritabanı (metrikler + instance kayıtları — izlediğiniz DB'ler değil)
PGWATCH_DB_PASSWORD=degistirin_guclu_sifre

# Instance bağlantı şifrelerini şifrelemek için (uzun rastgele metin, yedekleyin)
CREDENTIALS_MASTER_KEY=degistirin_en_az_32_karakter_rastgele_anahtar

# Web arayüzü portu (sunucuda: http://SUNUCU_IP:8080)
HTTP_PORT=8080

# Metrik toplama aralığı (saniye)
COLLECT_INTERVAL_SECONDS=15
