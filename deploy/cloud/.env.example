# Faz 1 — Bulut geliştirme (Supabase + Railway + Vercel)
# Kopya: cp .env.example .env  (yerel backend test için)

DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:SUPABASE_DB_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

RUN_MODE=all
CREDENTIALS_MASTER_KEY=dev-only-change-in-production-min-32-chars
COLLECT_INTERVAL_SECONDS=15

# public = multi-customer dashboard; private = single customer isolated
DEPLOYMENT_MODE=public
DEFAULT_CUSTOMER_NAME=

SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

CORS_ORIGINS=["http://localhost:5173"]

# Vercel (frontend build — Vercel panelinde de tanımlayın)
# VITE_API_URL=https://your-api.up.railway.app
