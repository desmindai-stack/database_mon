# Supabase project (Settings → API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Postgres — use Session pooler URI (IPv4) for SQLAlchemy worker/API
# Settings → Database → Connection string → URI (mode: session)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# Worker / API split (cloud)
# Local dev: all | Production API: api | Production collector: worker
RUN_MODE=all

COLLECT_INTERVAL_SECONDS=15
CREDENTIALS_MASTER_KEY=change-me-long-random-secret

# CORS (Vercel dashboard URL)
CORS_ORIGINS=["https://your-dashboard.vercel.app","http://localhost:5173"]
